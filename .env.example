# From @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated numeric IDs. Message @userinfobot on Telegram to see yours.
ALLOWED_CHAT_IDS=123456789

# Repo root for Cursor agent
AGENT_WORKDIR=/home/you/your-repo

# Binary on PATH or absolute path
CURSOR_BIN=cursor

# JSON array: all args before your prompt (prompt is appended as one argument)
CURSOR_ARGS_JSON=["agent"]

# Optional: chunk size for Telegram (max 4096)
# MAX_TELEGRAM_CHUNK=3800
